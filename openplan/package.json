{
  "name": "openplan",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:commerce-env": "vitest run src/test/billing-readiness.test.ts src/test/billing-webhook-utils.test.ts src/test/access-request-query.test.ts",
    "test:commerce-delivery": "vitest run src/test/billing-checkout-route.test.ts src/test/billing-checkout-launcher.test.tsx src/test/request-access-form.test.tsx src/test/access-request-route.test.ts",
    "test:public-catalog": "vitest run src/test/pricing-page.test.tsx src/test/request-access-page.test.tsx src/test/contact-page.test.tsx src/test/examples-page.test.tsx",
    "test:ai-planning-workflows-launch-dry-run": "vitest run src/test/billing-checkout-route.test.ts src/test/billing-readiness-route.test.ts",
    "test:workspace-selection-hardening": "vitest run src/test/workspace-membership-current.test.ts src/test/workspace-membership-query-guard.test.ts src/test/plans-route.test.ts src/test/programs-route.test.ts src/test/funding-opportunities-route.test.ts src/test/models-route.test.ts src/test/rtp-cycles-route.test.ts src/test/engagement-campaigns-route.test.ts src/test/current-workspace-route.test.ts src/test/assistant-context-route.test.ts src/test/assistant-route.test.ts",
    "test:rls-live": "OPENPLAN_RLS_LIVE_TEST=1 vitest run src/test/rls-isolation.test.ts",
    "test:watch": "vitest",
    "seed:workspace-isolation": "tsx scripts/seed-local-workspace-isolation.ts",
    "seed:nctc": "tsx scripts/seed-nctc-demo.ts",
    "ops:check-admin-operations-smoke": "node scripts/ops/check-admin-operations-smoke-prereqs.mjs",
    "ops:check-prod-health": "node scripts/ops/check-prod-health.mjs",
    "ops:log-prod-health-evidence": "node scripts/ops/log-prod-health-evidence.mjs",
    "ops:check-public-demo-preflight": "node scripts/ops/check-public-demo-preflight.mjs",
    "ops:webhook-proof": "tsx scripts/verify-webhook-ingestion.ts",
    "qa:gate": "npm run lint && npm test && COREPACK_ENABLE_STRICT=0 corepack pnpm@10.33.0 audit --prod --audit-level=moderate && npm run build",
    "qa:gate:log": "mkdir -p ../docs/ops/2026-03-01-test-output && (npm run qa:gate) | tee ../docs/ops/2026-03-01-test-output/2026-03-01-clean-gate.log",
    "ops:check-local-supabase-status": "node scripts/ops/check-local-supabase-status.mjs",
    "ops:check-migration-inventory": "node scripts/ops/check-migration-inventory.mjs",
    "ops:check-pilot-preflight": "node scripts/ops/check-pilot-preflight.mjs",
    "ops:generate-admin-pilot-readiness-proof-packet": "tsx scripts/ops/generate-admin-pilot-readiness-proof-packet.ts",
    "ops:check-admin-pilot-readiness-proof-packet-drift": "node scripts/ops/check-admin-pilot-readiness-proof-packet-drift.mjs",
    "test:sales-proof-claim-boundaries": "vitest run src/test/sales-proof-claim-boundaries.test.ts src/test/current-buyer-demo-proof-packet.test.ts",
    "test:guardrail-suite": "vitest run src/test/public-page-metadata-canonical-url.test.ts src/test/request-access-copy-to-admin-guard-trace.test.ts src/test/access-request-manual-provisioning-doc-index.test.ts src/test/billing-checkout-route.test.ts src/test/workspace-provision-route.test.ts src/test/workspace-membership-current.test.ts src/test/workspace-membership-required.test.tsx",
    "ops:check-buyer-demo-preflight": "node scripts/ops/check-buyer-demo-preflight.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.46",
    "@sparticuz/chromium": "^129.0.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.97.0",
    "ai": "^6.0.94",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^6.2.0",
    "lucide-react": "^0.575.0",
    "mapbox-gl": "^3.20.0",
    "marked": "^14.1.4",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "puppeteer-core": "^23.11.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "stripe": "^18.5.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "supabase": "^2.76.11",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "basic-ftp": "5.3.1",
    "fast-xml-builder": "1.1.7",
    "fast-xml-parser": "5.7.1",
    "ip-address": "10.1.1",
    "postcss": "8.5.14",
    "protocol-buffers-schema": "3.6.1",
    "ws": "8.20.1"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp@<=5.3.0": "5.3.1",
      "fast-xml-builder@<=1.1.6": "1.1.7",
      "fast-xml-parser@<5.7.0": "5.7.1",
      "ip-address@<=10.1.0": "10.1.1",
      "postcss@<8.5.14": "8.5.14",
      "protocol-buffers-schema@<3.6.1": "3.6.1",
      "ws@<8.20.1": "8.20.1"
    }
  }
}
