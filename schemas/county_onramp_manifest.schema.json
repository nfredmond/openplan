{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openplan.local/schemas/county_onramp_manifest.schema.json",
  "title": "OpenPlan County Onramp Manifest",
  "description": "Machine-readable status object for county validation-onramp workflow.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "generated_at",
    "name",
    "county_prefix",
    "run_dir",
    "mode",
    "stage",
    "artifacts",
    "runtime",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "openplan.county_onramp_manifest.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "county_fips": {
      "type": ["string", "null"]
    },
    "county_prefix": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["build-and-bootstrap", "existing-run"]
    },
    "stage": {
      "type": "string",
      "enum": [
        "bootstrap-incomplete",
        "runtime-complete",
        "validation-scaffolded",
        "validated-screening"
      ]
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "scaffold_csv",
        "review_packet_md",
        "run_summary_json",
        "bundle_manifest_json",
        "validation_summary_json"
      ],
      "properties": {
        "scaffold_csv": { "type": "string" },
        "review_packet_md": { "type": "string" },
        "run_summary_json": { "type": ["string", "null"] },
        "bundle_manifest_json": { "type": ["string", "null"] },
        "validation_summary_json": { "type": ["string", "null"] },
        "activitysim_bundle_manifest_json": { "type": ["string", "null"] },
        "behavioral_prototype_manifest_json": { "type": ["string", "null"] },
        "behavioral_runtime_manifest_json": { "type": ["string", "null"] },
        "behavioral_runtime_summary_json": { "type": ["string", "null"] },
        "behavioral_ingestion_summary_json": { "type": ["string", "null"] },
        "behavioral_kpi_summary_json": { "type": ["string", "null"] },
        "behavioral_kpi_packet_md": { "type": ["string", "null"] }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "keep_project",
        "force",
        "overall_demand_scalar",
        "external_demand_scalar",
        "hbw_scalar",
        "hbo_scalar",
        "nhb_scalar"
      ],
      "properties": {
        "keep_project": { "type": "boolean" },
        "force": { "type": "boolean" },
        "overall_demand_scalar": { "type": ["number", "null"] },
        "external_demand_scalar": { "type": ["number", "null"] },
        "hbw_scalar": { "type": ["number", "null"] },
        "hbo_scalar": { "type": ["number", "null"] },
        "nhb_scalar": { "type": ["number", "null"] }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["run", "validation", "bundle_validation"],
      "properties": {
        "run": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "zone_count",
            "population_total",
            "jobs_total",
            "loaded_links",
            "final_gap",
            "total_trips"
          ],
          "properties": {
            "zone_count": { "type": ["number", "null"] },
            "population_total": { "type": ["number", "null"] },
            "jobs_total": { "type": ["number", "null"] },
            "loaded_links": { "type": ["number", "null"] },
            "final_gap": { "type": ["number", "null"] },
            "total_trips": { "type": ["number", "null"] }
          }
        },
        "validation": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "bundle_validation": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "activitysim_bundle": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "status": { "type": "string", "enum": ["completed", "failed", "not-built"] },
            "output_dir": { "type": ["string", "null"] },
            "manifest_path": { "type": ["string", "null"] },
            "land_use_rows": { "type": ["number", "null"] },
            "households": { "type": ["number", "null"] },
            "persons": { "type": ["number", "null"] },
            "skim_mode": { "type": ["string", "null"], "enum": ["copy", "symlink", null] },
            "error": { "type": ["object", "null"], "additionalProperties": true }
          }
        },
        "behavioral_prototype": {
          "type": ["object", "null"],
          "additionalProperties": true,
          "properties": {
            "pipeline_status": {
              "type": ["string", "null"],
              "enum": [
                "prototype_preflight_complete",
                "behavioral_runtime_succeeded",
                "behavioral_runtime_failed",
                "prototype_pipeline_failed",
                "prototype_pipeline_running",
                null
              ]
            },
            "runtime_status": {
              "type": ["string", "null"],
              "enum": [
                "behavioral_runtime_blocked",
                "behavioral_runtime_succeeded",
                "behavioral_runtime_failed",
                null
              ]
            },
            "runtime_mode": { "type": ["string", "null"] },
            "output_root": { "type": ["string", "null"] },
            "prototype_manifest_path": { "type": ["string", "null"] },
            "runtime_manifest_path": { "type": ["string", "null"] },
            "runtime_summary_path": { "type": ["string", "null"] },
            "ingestion_summary_path": { "type": ["string", "null"] },
            "kpi_summary_path": { "type": ["string", "null"] },
            "kpi_packet_path": { "type": ["string", "null"] },
            "caveats": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
